# Neon PostgreSQL — pooled + direct connection
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Better Auth — secret: openssl rand -hex 32
BETTER_AUTH_SECRET=""

# Vercel Blob
BLOB_READ_WRITE_TOKEN=""

# Google OAuth — redirect URI: https://conexory.com/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Wompi — usar claves de producción en Production, de sandbox en Preview
WOMPI_PUBLIC_KEY=""
WOMPI_INTEGRITY_SECRET=""
WOMPI_EVENTS_SECRET=""

# Resend
RESEND_API_KEY=""
